{
  "name": "demos",
  "type": "module",
  "main": ".dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @teaui/term --filter @teaui/core --filter @teaui/react build && pnpm tsc",
    "checksum": "pnpm check --needs=.dist --needs=../../packages/core/.dist --needs=../../packages/react/.dist . ../../packages/core/lib ../../packages/react/lib 'pnpm build'",
    "demo": "pnpm checksum && cd .dist && node --enable-source-maps --",
    "clean": "rm -rf .dist/"
  },
  "private": true,
  "dependencies": {
    "@teaui/core": "workspace:*",
    "@teaui/react": "workspace:*",
    "react": "^18.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@teaui/shared": "workspace:*",
    "@types/react": "^18.3.1"
  }
}
