{
  "name": "@teaui/subprocess",
  "description": "Embed child terminal processes in a TeaUI view via PTY + xterm-headless",
  "author": "Colin T.A. Gray <colinta@colinta.com>",
  "version": "1.11.8",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git://github.com/colinta/teaui.git"
  },
  "homepage": "https://github.com/colinta/teaui",
  "exports": {
    ".": {
      "types": "./.dist/index.d.ts",
      "import": "./.dist/index.js",
      "default": "./.dist/index.js"
    },
    "./react": {
      "types": "./.dist/react.d.ts",
      "import": "./.dist/react.js",
      "default": "./.dist/react.js"
    }
  },
  "main": ".dist/index.js",
  "types": ".dist/index.d.ts",
  "files": [
    ".dist/"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf .dist/",
    "_build": "pnpm clean && pnpm tsc && pnpm tsc -p tsconfig.react.json",
    "build": "node ../../shared/check.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">= 18.12.0"
  },
  "dependencies": {
    "@teaui/core": "workspace:*",
    "node-pty": "^1.1.0",
    "@xterm/headless": "^5.5.0"
  },
  "peerDependencies": {
    "@teaui/react": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@teaui/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@teaui/shared": "workspace:*",
    "@teaui/react": "workspace:*",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "vitest": "^3.0.0"
  }
}
