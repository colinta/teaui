{
  "name": "@teaui/term",
  "version": "1.8.8",
  "description": "Zero-dependency TypeScript terminal library for modern terminals",
  "type": "module",
  "main": "./.dist/index.js",
  "types": "./.dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./.dist/index.d.ts",
      "import": "./.dist/index.js",
      "default": "./.dist/index.js"
    }
  },
  "scripts": {
    "_build": "pnpm clean && tsc",
    "build": "node ../../shared/check.js",
    "clean": "rm -rf .dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "example:speed": "npx tsx examples/speed.ts",
    "example:rain": "npx tsx examples/rain.ts",
    "example:mouse": "npx tsx examples/mouse.ts"
  },
  "devDependencies": {
    "@teaui/shared": "workspace:*",
    "@types/node": "^20.3.2",
    "tsx": "^4.21.0"
  },
  "files": [
    ".dist"
  ],
  "license": "MIT"
}
