{
  "name": "@teaui/term",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript terminal library for modern terminals",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "example:speed": "npx tsx examples/speed.ts",
    "example:rain": "npx tsx examples/rain.ts",
    "example:mouse": "npx tsx examples/mouse.ts"
  },
  "devDependencies": {
    "@types/node": "^20.3.2",
    "tsx": "^4.21.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
